{
  "name": "buddymon",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "buddymon": "bash ./buddymon.sh",
    "buddy": "npm run buddymon -- buddy",
    "scan": "npm run buddymon -- scan",
    "stats": "npm run buddymon -- stats",
    "export": "npm run buddymon -- export buddymon-card.json",
    "battle": "npm run buddymon -- battle",
    "arena": "npm run dev -w @buddymon/web",
    "build": "npm run build --workspaces",
    "build:shared": "npm run build -w @buddymon/shared",
    "build:cli": "npm run build -w @buddymon/cli",
    "build:web": "npm run build -w @buddymon/web",
    "test": "npm run test --workspaces --if-present"
  }
}
